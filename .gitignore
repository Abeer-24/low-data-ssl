# Python
venv/
__pycache__/
*.pyc
*.pyo

# Dataset -- large (~2.6GB), regenerated by data/stl10_loader.py, never commit
raw_data/

# Model checkpoints -- can be large; SimSiam encoders especially.
# Keep JSON results (small, needed for the comparison tables) but exclude
# the actual .pt weight files from git. Track them via a release/asset
# link in the README instead if you want them downloadable.
checkpoints/simsiam/*.pt
checkpoints/downstream/*.pt
checkpoints/deploy/*.pt

# Weights & Biases local run logs -- large, regenerated on every run,
# and results already synced to wandb.ai / saved as JSON separately.
wandb/

# OS/editor cruft
.vscode/
.DS_Store
Thumbs.db

# Environment secrets -- never commit API keys
.env
